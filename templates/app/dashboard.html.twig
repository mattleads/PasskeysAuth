{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <div style="max-width: 600px; margin: 50px auto; font-family: sans-serif; text-align: center;">
        <h1>Welcome, {{ app.user.email }}!</h1>
        <p>You have successfully logged in using your Passkey.</p>
        
        <a href="{{ path('app_logout') }}" style="display: inline-block; padding: 10px 20px; background: #dc3545; color: white; text-decoration: none; border-radius: 5px;">
            Logout
        </a>
    </div>
{% endblock %}
